{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".venv/**",
      "__pycache__/**",
      "app.py",
      "requirements.txt",
      "meals.json",
      "test_api.py",
      "dl.py",
      "run.err",
      "run.log",
      "Dockerfile",
      ".dockerignore"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
